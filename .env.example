# Required: Fernet encryption key + session signing
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=

# Required for Plex OAuth flow
PLEX_CLIENT_ID=

# Optional: database URL (defaults to sqlite:///data/greateye.db)
# DATABASE_URL=sqlite:///data/greateye.db
